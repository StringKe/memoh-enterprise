{
  "name": "@memohai/monorepo",
  "private": true,
  "version": "0.8.0",
  "scripts": {
    "docs:dev": "pnpm --filter @memohai/docs dev",
    "docs:build": "pnpm --filter @memohai/docs build",
    "docs:preview": "pnpm --filter @memohai/docs preview",
    "release": "bumpp",
    "release:patch": "bumpp patch --yes",
    "release:minor": "bumpp minor --yes",
    "release:major": "bumpp major --yes",
    "publish:npm": "node scripts/publish-packages.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.0.3",
    "bumpp": "^10.4.1",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8"
  },
  "lint-staged": {
    "*.{vue,js,ts,md,json,scss}": [
      "eslint --fix --concurrency=auto"   
    ]
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@algolia/client-search"
      ]
    }
  }
}
