{
  "name": "@stringke/monorepo",
  "version": "0.8.0",
  "private": true,
  "keywords": [],
  "license": "ISC",
  "author": "",
  "scripts": {
    "release": "bumpp",
    "release:patch": "bumpp patch --yes",
    "release:minor": "bumpp minor --yes",
    "release:major": "bumpp major --yes",
    "publish:packages": "node scripts/release/publish-packages.mjs",
    "proto:lint": "buf lint",
    "proto:generate": "buf generate --template buf.gen.go.yaml && buf generate --template buf.gen.ts.yaml && vp check --fix packages/sdk/src/gen",
    "proto:generate:go": "buf generate --template buf.gen.go.yaml",
    "proto:generate:ts": "buf generate --template buf.gen.ts.yaml && vp check --fix packages/sdk/src/gen",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "test": "vp test",
    "prepare": "husky"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "bumpp": "^10.4.1",
    "husky": "^9.1.7",
    "typescript": "^5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "^0.1.20"
  },
  "packageManager": "pnpm@10.27.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "@algolia/client-search"
      ]
    }
  }
}
