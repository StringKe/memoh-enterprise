{
  "name": "@stringke/browser-gateway",
  "version": "0.8.0",
  "type": "module",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outfile dist/index.js --target bun --minify --external playwright --external playwright-core",
    "start": "pnpm run build && bun run dist/index.js"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@stringke/config": "workspace:*",
    "elysia": "1",
    "playwright": "1.50.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "1",
    "bun-types": "^1.3.10",
    "typescript": "5"
  }
}
